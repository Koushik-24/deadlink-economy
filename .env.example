# DeadLink Economy — Environment Variables
# ─────────────────────────────────────────────────────────
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to GitHub (it's in .gitignore)

# ─── STRIPE ──────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Get from: Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
# Starts with whsec_...
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─── APP ─────────────────────────────────────────────────
# Your production URL — no trailing slash
# Example: https://deadlink-economy.onrender.com
DOMAIN=https://your-app-name.onrender.com

# Port (Render sets this automatically — don't change)
PORT=3000

# ─── ADMIN DASHBOARD ─────────────────────────────────────
# Protects GET /api/admin/stats
# Set to any long random string — used as x-admin-key header
ADMIN_KEY=replace-with-a-long-random-secret-string-here
